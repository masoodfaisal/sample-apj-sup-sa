{
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "id": null,
  "uid": "claude-code-proxy",
  "title": "Claude Code Proxy - Gateway Metrics",
  "tags": [
    "claude-code",
    "proxy",
    "bedrock"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(gateway_request_count_total, resolved_model)",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "team",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(gateway_request_count_total, team_id)",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "user",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(gateway_request_count_total, user_id)",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "🔎 Overview",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Requests (1h)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(gateway_request_count_total{resolved_model=~\"$model\"}[1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "#73BF69",
                "value": null
              },
              {
                "color": "#FF9830",
                "value": 1000
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Error Rate (1h)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(gateway_request_count_total{resolved_model=~\"$model\", status!=\"success\"}[1h])) / sum(increase(gateway_request_count_total{resolved_model=~\"$model\"}[1h])) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "#73BF69",
                "value": null
              },
              {
                "color": "#FF9830",
                "value": 5
              },
              {
                "color": "#F2495C",
                "value": 20
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Tokens (1h)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_token_usage_tokens_total{resolved_model=~\"$model\"}[1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "#8AB8FF",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Estimated Cost (1h)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total{resolved_model=~\"$model\"}[1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "#B877D9",
                "value": null
              },
              {
                "color": "#FF9830",
                "value": 10
              },
              {
                "color": "#F2495C",
                "value": 50
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Active Requests",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "clamp_min(sum(gateway_active_requests), 0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "#73BF69",
                "value": null
              },
              {
                "color": "#FF9830",
                "value": 10
              },
              {
                "color": "#F2495C",
                "value": 20
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Throttles (1h)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(gateway_throttle_count_total{resolved_model=~\"$model\"}[1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "#73BF69",
                "value": null
              },
              {
                "color": "#FF9830",
                "value": 5
              },
              {
                "color": "#F2495C",
                "value": 20
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "📊 Request Analysis",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Requests by Model",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (resolved_model)(rate(gateway_request_count_total{resolved_model=~\"$model\"}[5m]))",
          "legendFormat": "{{ resolved_model }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15
          }
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Latency (p50 / p90 / p99)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le)(rate(gateway_request_duration_milliseconds_bucket{resolved_model=~\"$model\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le)(rate(gateway_request_duration_milliseconds_bucket{resolved_model=~\"$model\"}[5m])))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le)(rate(gateway_request_duration_milliseconds_bucket{resolved_model=~\"$model\"}[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 13,
      "type": "piechart",
      "title": "Request Status Distribution",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (status)(increase(gateway_request_count_total{resolved_model=~\"$model\"}[$__range]))",
          "legendFormat": "{{ status }}"
        }
      ],
      "options": {
        "pieType": "donut",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        }
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "🪙 Tokens & Cost",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Token Usage by Type",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 15
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (type)(rate(claude_code_token_usage_tokens_total{resolved_model=~\"$model\"}[5m]))",
          "legendFormat": "{{ type }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "tokens/s",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "id": 22,
      "type": "barchart",
      "title": "Cost by Model",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 15
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (resolved_model)(increase(claude_code_cost_usage_USD_total[$__range]))",
          "legendFormat": "{{ resolved_model }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "fillOpacity": 80
          }
        }
      }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Cost Over Time",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 15
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (resolved_model)(rate(claude_code_cost_usage_USD_total{resolved_model=~\"$model\"}[5m])) * 3600",
          "legendFormat": "{{ resolved_model }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "🏦 Budget & Utilization",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "gauge",
      "title": "Budget Utilization by Scope (latest)",
      "description": "Current spend as % of hard limit. Red ≥ 90% = near-limit alert.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "gateway_budget_utilization_percent{scope_type=~\"USER|TEAM\"}",
          "legendFormat": "{{ scope_type }} / {{ budget_id }} / {{ period }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 120,
          "thresholds": {
            "steps": [
              {
                "color": "#73BF69",
                "value": null
              },
              {
                "color": "#FF9830",
                "value": 70
              },
              {
                "color": "#F2495C",
                "value": 90
              }
            ]
          }
        }
      }
    },
    {
      "id": 32,
      "type": "table",
      "title": "Cost by Team (period)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (team_id)(increase(claude_code_cost_usage_USD_total{team_id=~\"$team\"}[$__range]))",
          "legendFormat": "{{ team_id }}",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "team_id": "Team",
              "Value": "Cost (USD)"
            }
          }
        }
      ]
    },
    {
      "id": 33,
      "type": "table",
      "title": "Cost by User (period)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "topk(20, sum by (user_id)(increase(claude_code_cost_usage_USD_total{user_id=~\"$user\"}[$__range])))",
          "legendFormat": "{{ user_id }}",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "user_id": "User",
              "Value": "Cost (USD)"
            }
          }
        }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "📦 Prompt Caching",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "collapsed": false
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Cache Hit Ratio (cacheRead / total input)",
      "description": "Higher = more cache reuse, lower cost.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 33
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(claude_code_token_usage_tokens_total{type=\"cacheRead\", resolved_model=~\"$model\"}[5m])) / (sum(rate(claude_code_token_usage_tokens_total{type=\"input\", resolved_model=~\"$model\"}[5m])) + sum(rate(claude_code_token_usage_tokens_total{type=\"cacheRead\", resolved_model=~\"$model\"}[5m]))) * 100",
          "legendFormat": "Cache Hit %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 42,
      "type": "timeseries",
      "title": "Cache Tokens: Read vs Creation",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 33
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(claude_code_token_usage_tokens_total{type=\"cacheRead\", resolved_model=~\"$model\"}[5m]))",
          "legendFormat": "cacheRead"
        },
        {
          "expr": "sum(rate(claude_code_token_usage_tokens_total{type=\"cacheCreation\", resolved_model=~\"$model\"}[5m]))",
          "legendFormat": "cacheCreation"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "tokens/s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15
          }
        }
      }
    },
    {
      "id": 43,
      "type": "piechart",
      "title": "Cache Policy Distribution",
      "description": "Requests by cache_policy setting (none / 5m / 1h).",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 33
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (cache_policy)(increase(gateway_request_count_total{resolved_model=~\"$model\"}[$__range]))",
          "legendFormat": "{{ cache_policy }}"
        }
      ],
      "options": {
        "pieType": "donut",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        }
      }
    },
    {
      "id": 50,
      "type": "row",
      "title": "⚡ Throttling & Policy Blocks",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 41
      },
      "collapsed": false
    },
    {
      "id": 51,
      "type": "timeseries",
      "title": "Throttle Rate by Model",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 42
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (resolved_model)(rate(gateway_throttle_count_total{resolved_model=~\"$model\"}[5m]))",
          "legendFormat": "{{ resolved_model }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15
          }
        }
      }
    },
    {
      "id": 52,
      "type": "timeseries",
      "title": "Policy Blocks by Reason",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 42
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (block_reason)(rate(gateway_policy_block_count_total[5m]))",
          "legendFormat": "{{ block_reason }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "id": 53,
      "type": "timeseries",
      "title": "Active In-Flight Requests",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 42
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "clamp_min(sum(gateway_active_requests), 0)",
          "legendFormat": "active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 60,
      "type": "row",
      "title": "🚀 Streaming TTFB",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 50
      },
      "collapsed": false
    },
    {
      "id": 61,
      "type": "timeseries",
      "title": "TTFB (p50 / p90 / p99)",
      "description": "Time to first byte for streaming responses.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 51
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le)(rate(gateway_stream_ttfb_milliseconds_bucket{resolved_model=~\"$model\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le)(rate(gateway_stream_ttfb_milliseconds_bucket{resolved_model=~\"$model\"}[5m])))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le)(rate(gateway_stream_ttfb_milliseconds_bucket{resolved_model=~\"$model\"}[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
