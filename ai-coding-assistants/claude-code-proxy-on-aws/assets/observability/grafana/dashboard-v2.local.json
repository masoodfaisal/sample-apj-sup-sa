      },
      "targets": [
        {
          "expr": "sum(rate(claude_code_token_usage_tokens_total{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\",type=\"cacheRead\"}[5m]))",
          "legendFormat": "cacheRead"
        },
        {
          "expr": "sum(rate(claude_code_token_usage_tokens_total{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\",type=\"cacheCreation\"}[5m]))",
