          "expr": "sum(rate(claude_code_token_usage_tokens_total{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\",type=\"cacheRead\"}[5m])) / clamp_min(sum(rate(claude_code_token_usage_tokens_total{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\",type=~\"input|cacheRead\"}[5m])), 1) * 100",
