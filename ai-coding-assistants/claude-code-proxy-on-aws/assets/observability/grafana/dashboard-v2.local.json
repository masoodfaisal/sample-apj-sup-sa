    {
      "id": 115,
      "type": "piechart",
      "title": "Requests by Stream Mode",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (stream)(increase(gateway_request_count_total{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\"}[$__range]))",
          "legendFormat": "{{ stream }}"
        }
      ],
      "options": {
        "pieType": "donut",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        }
      }
    },
    {
      "id": 116,
      "type": "piechart",
      "title": "Token Usage by Model",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (resolved_model)(increase(claude_code_token_usage_tokens_total{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\"}[$__range]))",
          "legendFormat": "{{ resolved_model }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
