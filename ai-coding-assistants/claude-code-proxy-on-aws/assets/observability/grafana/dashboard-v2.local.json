    {
      "id": 121,
      "type": "gauge",
      "title": "Budget Utilization by Scope (latest)",
      "description": "Current spend as % of hard limit. Red \u2265 90% = near-limit alert.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 35
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "gateway_budget_utilization_percent{scope_type=~\"USER|TEAM\"}",
          "legendFormat": "{{ scope_type }} / {{ budget_id }} / {{ period }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 120,
          "thresholds": {
            "steps": [
              {
                "color": "#73BF69",
                "value": null
              },
              {
                "color": "#FF9830",
                "value": 70
              },
              {
                "color": "#F2495C",
                "value": 90
              }
            ]
          }
        }
      }
    },
    {
      "id": 122,
      "type": "table",
      "title": "Cost by Team (period)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 35
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "topk(50, sum by (team_id)(increase(claude_code_cost_usage_USD_total{resolved_model=~\"$model\",team_id=~\"$team\"}[$__range])))",
          "legendFormat": "{{ team_id }}",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "team_id": "Team",
              "Value": "Cost (USD)"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "countRows": false
        },
        "sortBy": [
          {
            "displayName": "Value",
            "desc": true
          }
        ],
        "enablePagination": true
      }
    },
    {
      "id": 123,
      "type": "table",
