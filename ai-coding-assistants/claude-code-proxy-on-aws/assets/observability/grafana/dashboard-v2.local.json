        }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "user_id": "User",
              "Value": "Cost (USD)"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "countRows": false
        },
        "sortBy": [
          {
            "displayName": "Value",
            "desc": true
          }
        ],
        "enablePagination": true
      }
    },
