{
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "id": null,
  "uid": null,
  "title": "Claude Code Proxy - Gateway Metrics v2",
  "tags": [
    "claude-code",
    "proxy",
    "bedrock"
  ],
  "timezone": "browser",
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(gateway_request_count_total, resolved_model)",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "team",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(gateway_request_count_total, team_id)",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "user",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(gateway_request_count_total, user_id)",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "\ud83d\udd0e Executive KPIs",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 101,
      "type": "stat",
      "title": "Total Requests",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(gateway_request_count_total{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\"}[$__range]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "#73BF69",
                "value": null
              },
              {
                "color": "#FF9830",
                "value": 5000
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 102,
      "type": "stat",
      "title": "Total Cost",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\"}[$__range]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "#B877D9",
                "value": null
              },
              {
                "color": "#FF9830",
                "value": 10
              },
              {
                "color": "#F2495C",
                "value": 50
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 103,
      "type": "stat",
      "title": "Real-Time Cost Burn Rate ($/hour)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(claude_code_cost_usage_USD_total{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\"}[5m])) * 3600"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "#B877D9",
                "value": null
              },
              {
                "color": "#FF9830",
                "value": 10
              },
              {
                "color": "#F2495C",
                "value": 50
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 104,
      "type": "stat",
      "title": "Avg API Latency",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(gateway_request_duration_milliseconds_sum{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\"}[5m])) / clamp_min(sum(rate(gateway_request_duration_milliseconds_count{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\"}[5m])), 1)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "#73BF69",
                "value": null
              },
              {
                "color": "#FF9830",
                "value": 1000
              }
            ]
          },
          "unit": "ms"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 105,
      "type": "gauge",
      "title": "API Error Rate",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(gateway_request_count_total{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\",status=~\"ERROR_.*\"}[$__range])) / clamp_min(sum(increase(gateway_request_count_total{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\"}[$__range])), 1) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "#73BF69",
                "value": null
              },
              {
                "color": "#FF9830",
                "value": 5
              },
              {
                "color": "#F2495C",
                "value": 20
              }
            ]
          }
        }
      }
    },
    {
      "id": 106,
      "type": "gauge",
      "title": "Policy Block Rate",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(gateway_request_count_total{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\",status=~\"BLOCKED_.*\"}[$__range])) / clamp_min(sum(increase(gateway_request_count_total{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\"}[$__range])), 1) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "#73BF69",
                "value": null
              },
              {
                "color": "#FF9830",
                "value": 5
              },
              {
                "color": "#F2495C",
                "value": 20
              }
            ]
          }
        }
      }
    },
    {
      "id": 107,
      "type": "gauge",
      "title": "Cache Hit Ratio",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_token_usage_tokens_total{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\",type=\"cacheRead\"}[$__range])) / clamp_min(sum(increase(claude_code_token_usage_tokens_total{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\",type=~\"input|cacheRead\"}[$__range])), 1) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "#F2495C",
                "value": null
              },
              {
                "color": "#FF9830",
                "value": 50
              },
              {
                "color": "#73BF69",
                "value": 80
              }
            ]
          }
        }
      }
    },
    {
      "id": 108,
      "type": "stat",
      "title": "Active Requests",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(gateway_active_requests{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "#73BF69",
                "value": null
              },
              {
                "color": "#FF9830",
                "value": 10
              },
              {
                "color": "#F2495C",
                "value": 20
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 110,
      "type": "row",
      "title": "\ud83e\ude99 Cost & Tokens",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 111,
      "type": "timeseries",
      "title": "Cost Over Time",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (resolved_model)(rate(claude_code_cost_usage_USD_total{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\"}[5m])) * 3600",
          "legendFormat": "{{ resolved_model }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 112,
      "type": "timeseries",
      "title": "Token Usage by Type",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (type)(rate(claude_code_token_usage_tokens_total{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\"}[5m]))",
          "legendFormat": "{{ type }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "tokens/s",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "id": 113,
      "type": "barchart",
      "title": "Cost by Model",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (resolved_model)(increase(claude_code_cost_usage_USD_total{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\"}[$__range]))",
          "legendFormat": "{{ resolved_model }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "fillOpacity": 80
          }
        }
      }
    },
    {
      "id": 114,
      "type": "timeseries",
      "title": "Requests by Model",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (resolved_model)(rate(gateway_request_count_total{resolved_model=~\"$model\",team_id=~\"$team\",user_id=~\"$user\"}[5m]))",
          "legendFormat": "{{ resolved_model }}"
        }
      ],
      "fieldConfig": {
